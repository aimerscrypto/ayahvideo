# ==============================================================================
# Quran Video Generator - Environment Variables Configuration Template
# Copy this file to '.env' and populate with your actual keys.
# ==============================================================================

# ------------------------------------------------------------------------------
# LLM Provider API Keys (At least one must be configured)
# ------------------------------------------------------------------------------

# API Key for Fireworks AI. Used for verse discovery and segment alignment.
FIREWORKS_API_KEY=your_fireworks_api_key_here

# Primary API Key for OpenRouter. Used for verse splitting and translation alignment.
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: Secondary, tertiary, and quaternary backup keys for OpenRouter.
# Used sequentially as fallbacks to prevent rate limits or request errors.
OPENROUTER_API_KEY_2=your_openrouter_api_key_2_here
OPENROUTER_API_KEY_3=your_openrouter_api_key_3_here
OPENROUTER_API_KEY_4=your_openrouter_api_key_4_here

# ------------------------------------------------------------------------------
# Video Customization
# ------------------------------------------------------------------------------

# Optional: URL of the background video loop.
# If not specified, defaults to https://pub-0a47df772c2d4d2e838dad7de6d2b237.r2.dev/bg.mp4
# BG_VIDEO_URL=https://your-custom-video-hosting-url.mp4
